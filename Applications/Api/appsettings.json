{
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:localhost,1433;Database={{ProjectName}};Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "",
    "Issuer": "{{ProjectName}}",
    "Audience": "{{ProjectName}}",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
